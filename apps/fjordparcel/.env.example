SECRET_KEY=change-me-to-a-long-random-string
APP_ENCRYPTION_KEY=
PUBLIC_BASE_URL=http://localhost:8096
# DATA_DIR=./data
DATABASE_PATH=data/fjordparcel.db
APP_CONFIG_PATH=data/app_config.json
MS_TOKEN_CACHE_PATH=data/msal_cache.json

# Use "consumers" for Hotmail/Outlook personal accounts.
# Use "common" if you want both personal and work/school Microsoft accounts.
MS_TENANT=consumers
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_IMAP_HOST=outlook.office365.com
MS_IMAP_PORT=993
MS_IMAP_MAX_SCAN_MESSAGES=1000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_GMAIL_MAX_SCAN_MESSAGES=1000

# PostNord tracking hentes via 17TRACK.
# TRACK17_SIGN kan opdateres fra browser-kaldet til https://t.17track.net/track/restapi (request body -> sign).
# TRACK17_SIGN=
# TRACK17_TIMEZONE_OFFSET=-480

# In-app FjordParcel updater. docker-compose.yml saetter FJORDPARCEL_UPDATER_URL internt.
# FJORDPARCEL_UPDATER_TIMEOUT_SEC=20
# FJORDPARCEL_AUTO_UPDATE_CHECK=1
# FJORDPARCEL_AUTO_UPDATE_CHECK_INTERVAL_MINUTES=30
