# Host port for the web UI
APP_PORT=9080

# Absolute host path to this repo. The updater container uses it as /repo.
# FjordHub fills this automatically during Hub installs; manual setup scripts set it to the current repo.
# APP_REPO_DIR=/volume1/docker/fjordlens

# Synology paths (default: folders inside /volume1/docker/fjordlens)
# Optional library source mount (used only when ENABLE_LIBRARY_SOURCE=1).
# You can comment this out if you only use uploads.
# PHOTO_DIR=/volume1/docker/fjordlens/Photos
DATA_DIR=/volume1/docker/fjordlens/data
UPLOADS_HOST_DIR=/volume1/docker/fjordlens/data/uploads
THUMBS_HOST_DIR=/volume1/docker/fjordlens/data/thumbs

# Note:
# - Upload folders (originals + converted) live under UPLOADS_HOST_DIR.
# - Thumbnails live under THUMBS_HOST_DIR.
# - Remaining app state (db, cache, temp, secrets) lives under DATA_DIR.
# On first start, the app auto-creates:
# - UPLOADS_HOST_DIR/originals
# - UPLOADS_HOST_DIR/converted
# - THUMBS_HOST_DIR
# - converted          (internal cache for viewable copies)
# - tus_uploads        (temporary uploads)

# Convert uploaded .mov videos to browser-friendly .mp4 during upload postprocess.
RAW_CONVERT_ON_UPLOAD=1
MOV_CONVERT_ON_UPLOAD=1
# MOV_CONVERT_PRESET=veryfast
# MOV_CONVERT_CRF=23
# MOV_CONVERT_AUDIO_BITRATE=128k
# MOV_CONVERT_TIMEOUT_SEC=7200

# Flask / app settings
TZ=Europe/Copenhagen
LOG_LEVEL=INFO

# Weather enrichment for photos with date + GPS, or date + city fallback.
# Uses Open-Meteo by default and stores the result in photo metadata.
WEATHER_AUTO_FETCH=1
# WEATHER_HISTORY_API_URL=https://archive-api.open-meteo.com/v1/archive
# WEATHER_GEOCODING_API_URL=https://geocoding-api.open-meteo.com/v1/search

# AI device preference: auto (use CUDA if available), cpu, or cuda (force attempt)
AI_DEVICE=auto
# Default description model in FjordLens app: light or qwen
AI_DESC_MODEL=qwen
# Max seconds the web app waits for one Qwen description request before moving on
AI_DESC_REQUEST_TIMEOUT_SEC=120
# Local Qwen VL model (used when AI_DESC_MODEL=qwen or selected in UI dropdown)
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
# Enable 4-bit quantization when bitsandbytes is available (recommended on 6 GB VRAM)
QWEN_VL_4BIT=1
# fp4 is more compatible on some small CUDA/bitsandbytes setups than nf4
QWEN_VL_4BIT_QUANT_TYPE=fp4
# Move CLIP/face runtime to CPU before loading Qwen so small GPUs have enough room
QWEN_VL_RESERVE_GPU=1
# Keep Qwen from falling back to system RAM on small hosts
QWEN_VL_CPU_FALLBACK=0
QWEN_VL_LOW_CPU_MEM_USAGE=1
# Max generated tokens for Qwen descriptions
QWEN_VL_MAX_NEW_TOKENS=120
# Downscale only the image sent to Qwen; originals stay untouched (good default for 6 GB VRAM)
QWEN_VL_MAX_IMAGE_SIDE=1280
QWEN_VL_MAX_IMAGE_PIXELS=1500000
# LXC setup helper: when 1, scripts/fresh_setup_lxc.sh runs guided GPU preflight/fixes
ENABLE_GPU_GUIDE=1

# SQLite tuning
# Use WAL on local disks, but prefer DELETE on NFS/CIFS mounts to avoid lock/crash issues.
SQLITE_JOURNAL_MODE=WAL
SQLITE_BUSY_TIMEOUT_MS=10000

# Library source (PHOTO_DIR). 0 disables library usage completely.
ENABLE_LIBRARY_SOURCE=0

# Scan features (scan/rescan/rethumb). 0 disables the scan UI and endpoints.
ENABLE_SCAN_FEATURES=0

# In-app FjordLens updater. docker-compose.yml sets FJORDLENS_UPDATER_URL internally.
# Increase this only if update status/check calls need longer proxy timeouts.
# FJORDLENS_UPDATER_TIMEOUT_SEC=20
# Defaults for the updater service before UI settings are saved.
# FJORDLENS_AUTO_UPDATE_CHECK=1
# FJORDLENS_AUTO_UPDATE_CHECK_INTERVAL_MINUTES=30

# Optional FjordHub integration. FjordHub-managed installs fill these automatically.
# FJORDHUB_URL=http://host.docker.internal:8091
# FJORDHUB_APP_ID=fjordlens
# FJORDHUB_API_KEY=

# Optional strict mount checks for scripts/fresh_setup.sh (comma-separated fstypes).
# Useful on Proxmox + Synology NFS to fail fast if mounts are not active.
# EXPECT_UPLOADS_FSTYPES=nfs,nfs4
# EXPECT_THUMBS_FSTYPES=nfs,nfs4
# EXPECT_DATA_FSTYPES=ext4,xfs,btrfs,nfs,nfs4
# EXPECT_PHOTO_FSTYPES=nfs,nfs4

# Optional setup metadata used by scripts/fresh_setup.sh when rerunning wizard.
# SETUP_NFS_UPLOADS_ENABLED=0
# SETUP_NFS_EXPORT=10.10.0.161:/volume1/ProxmoxFjordlens
# SETUP_NFS_MOUNT_ROOT=/home/qlerup/synology/fjordlens-data
# SETUP_NFS_UPLOADS_SUBDIR=uploads
# SETUP_NFS_FSTAB_OPTIONS=vers=3,_netdev,nofail

# Photoframe feed mode: 0 = real images, 1 = test status card only
PHOTOFRAME_TEXT_ONLY=0

# Max uploaded update zip size in bytes (300 MB default)
PHOTOFRAME_UPDATE_UPLOAD_MAX_BYTES=314572800
