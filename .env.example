# FjordHub configuration
# Copy this file to .env and fill in your values

# Port FjordHub listens on (direct access, bypasses Traefik)
APP_PORT=8888

# Traefik ports
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# Data directory for FjordHub state
DATA_DIR=./data

# Secret key for Flask sessions - CHANGE THIS in production
SECRET_KEY=change-me-in-production

# Timezone
TZ=Europe/Copenhagen

# URL to the registry.json file in FjordHub's GitHub repo (raw content URL).
# Replace OWNER with your GitHub username/org. Once set, FjordHub automatically
# discovers new apps without requiring any local update.
REGISTRY_URL=https://raw.githubusercontent.com/qlerup/fjordhub/main/registry.json

# Host path to FjordHub's own directory — enables self-update via Settings > Opdatering
# Use an absolute path in production; "." works when docker compose is run from the repo directory.
FJORDHUB_HOST_DIR=/opt/fjordhub

# Docker image used by FjordHub's privileged helper jobs.
FJORDHUB_IMAGE=fjordhub-fjordhub:latest

# Absolute paths to each app's directory on the HOST (where docker-compose.yml lives)
# FjordHub uses these to start/stop apps via docker compose
FJORDLENS_DIR=/opt/fjordlens
FJORDSHARE_DIR=/opt/fjordshare
FJORDPARCEL_DIR=/opt/fjordparcel
