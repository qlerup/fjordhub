{
  "id": "fjordlens",
  "name": "FjordLens",
  "tagline": "AI-drevet fotobibliotek",
  "description": "Organiser og søg i dine fotos med AI-beskrivelser, ansigtsgenkendelse og automatisk tagging.",
  "icon": "camera",
  "accent": "#3b82f6",
  "container_name": "fjordlens",
  "default_port": 9080,
  "health_path": "/api/health",
  "traefik_prefix": "/lens",
  "compose_dir_env": "FJORDLENS_DIR",
  "source_url": "https://github.com/qlerup/fjordlens",
  "icon_url": "https://raw.githubusercontent.com/qlerup/fjordlens/main/static/logos/icons/fjordlens-mark-transparent-512.png",
  "sort_order": 1,
  "setup_steps": [
    {
      "id": "basic",
      "title": "Grundlæggende indstillinger",
      "fields": [
        {
          "key": "APP_PORT",
          "label": "Web-port",
          "type": "number",
          "default": "9080",
          "hint": "Den port du åbner i browseren, f.eks. 9080"
        },
        {
          "key": "TZ",
          "label": "Tidszone",
          "type": "text",
          "default": "Europe/Copenhagen",
          "hint": "Region/By-format, f.eks. Europe/Copenhagen"
        },
        {
          "key": "LOG_LEVEL",
          "label": "Log-niveau",
          "type": "select",
          "default": "INFO",
          "hint": "DEBUG viser flere detaljer",
          "options": [
            {"value": "INFO", "label": "INFO (anbefalet)"},
            {"value": "DEBUG", "label": "DEBUG"}
          ]
        }
      ]
    },
    {
      "id": "gpu",
      "title": "GPU (valgfrit)",
      "gpu_helper": true,
      "fields": [
        {
          "key": "ENABLE_GPU_COMPOSE",
          "label": "Aktiver NVIDIA GPU passthrough",
          "type": "toggle",
          "default": "0",
          "hint": "Slå kun til efter GPU-testen er OK. Ellers installeres FjordLens sikkert på CPU."
        },
        {
          "key": "AI_DEVICE",
          "label": "AI-enhed",
          "type": "select",
          "default": "cpu",
          "hint": "CPU virker på alle hosts. Auto/CUDA bruges sammen med GPU passthrough.",
          "options": [
            {"value": "cpu", "label": "CPU (anbefalet)"},
            {"value": "auto", "label": "Auto"},
            {"value": "cuda", "label": "CUDA (NVIDIA GPU)"}
          ]
        }
      ]
    },
    {
      "id": "storage",
      "title": "Lagerplads",
      "fields": [
        {
          "key": "DATA_DIR",
          "label": "Data-mappe (database, cache, hemmeligheder)",
          "type": "path",
          "default": "/opt/fjordlens-data/appdata",
          "hint": "Absolut sti på serveren. Bør ligge på lokal disk."
        },
        {
          "key": "UPLOADS_HOST_DIR",
          "label": "Upload-mappe (originaler og konverterede filer)",
          "type": "path",
          "default": "/opt/fjordlens-data/uploads",
          "hint": "Kan ligge på NAS/NFS. Undermapper oprettes automatisk."
        },
        {
          "key": "THUMBS_HOST_DIR",
          "label": "Thumbnail-mappe",
          "type": "path",
          "default": "/opt/fjordlens-data/thumbs",
          "hint": "Lokal disk anbefales for bedre ydelse."
        }
      ]
    },
    {
      "id": "library",
      "title": "Fotobibliotek (valgfrit)",
      "fields": [
        {
          "key": "ENABLE_LIBRARY_SOURCE",
          "label": "Aktiver separat skrivebeskyttet fotobibliotek",
          "type": "toggle",
          "default": "0",
          "hint": "Giver FjordLens adgang til et eksisterende fotoarkiv (f.eks. Synology)"
        },
        {
          "key": "PHOTO_DIR",
          "label": "Fotobibliotek-sti (PHOTO_DIR)",
          "type": "path",
          "default": "/mnt/photos",
          "hint": "Absolut sti til dit eksisterende fotoarkiv",
          "show_if": {"key": "ENABLE_LIBRARY_SOURCE", "value": "1"}
        }
      ]
    },
    {
      "id": "updater",
      "title": "Automatisk opdatering",
      "fields": [
        {
          "key": "FJORDLENS_AUTO_UPDATE_CHECK",
          "label": "Tjek automatisk for opdateringer",
          "type": "toggle",
          "default": "1",
          "hint": "FjordLens tjekker GitHub for nye versioner i baggrunden"
        },
        {
          "key": "FJORDLENS_AUTO_UPDATE_CHECK_INTERVAL_MINUTES",
          "label": "Tjek-interval (minutter)",
          "type": "number",
          "default": "30",
          "hint": "Minimum 5 minutter",
          "show_if": {"key": "FJORDLENS_AUTO_UPDATE_CHECK", "value": "1"}
        }
      ]
    }
  ]
}
